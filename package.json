{
  "name": "alpinejs-tools",
  "displayName": "Alpine.js Tools",
  "description": "Alpine.js IntelliSense, syntax highlighting, and tooling for VS Code",
  "version": "1.1.0",
  "publisher": "connorontheweb",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ConnorOnTheWeb/alpinejs-tools"
  },
  "bugs": {
    "url": "https://github.com/ConnorOnTheWeb/alpinejs-tools/issues"
  },
  "homepage": "https://github.com/ConnorOnTheWeb/alpinejs-tools#readme",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "alpine",
    "alpinejs",
    "alpine.js",
    "intellisense",
    "autocomplete",
    "snippets",
    "syntax",
    "highlighting",
    "ejs",
    "html"
  ],
  "icon": "images/alpinejs-tools.png",
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:ejs",
    "onLanguage:php",
    "onLanguage:twig",
    "onLanguage:nunjucks",
    "onLanguage:blade"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "grammars": [
      {
        "scopeName": "alpinejs.injection",
        "path": "./syntaxes/alpine-injection.tmLanguage.json",
        "injectTo": [
          "text.html.basic",
          "text.html.ejs",
          "text.html.php",
          "text.html.twig"
        ]
      }
    ],
    "html/customData": [
      "./customData/alpine.html-data.json"
    ],
    "snippets": [
      { "language": "html",       "path": "./snippets/alpine.code-snippets" },
      { "language": "ejs",        "path": "./snippets/alpine.code-snippets" },
      { "language": "php",        "path": "./snippets/alpine.code-snippets" },
      { "language": "twig",       "path": "./snippets/alpine.code-snippets" },
      { "language": "nunjucks",   "path": "./snippets/alpine.code-snippets" },
      { "language": "javascript", "path": "./snippets/alpine.code-snippets" }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.118.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
